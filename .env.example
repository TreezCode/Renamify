# Site URL for local development (optional - falls back to localhost:3000)
# Used for OG images and metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel automatically sets VERCEL_URL in preview/production deployments
# No need to set this manually in Vercel

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
# Go to Project Settings → API → API Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Note: Supabase uses publishable keys (sb_publishable_xxx) for improved security
# Legacy anon keys still work during the transition period
